#!/usr/bin/env bash
# ai-runtime — wire the shared AI Runtime into your global agent config (~/.claude).
set -euo pipefail

CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
GLOBAL_MD="$CLAUDE_DIR/CLAUDE.md"
LINK="$CLAUDE_DIR/ai-runtime"
SETTINGS="$CLAUDE_DIR/settings.json"
BEGIN="# >>> ai-runtime >>>"
END="# <<< ai-runtime <<<"

# Resolve the runtime content root:
#  1. $AI_RUNTIME_HOME (set by the Homebrew wrapper), else
#  2. the repo root relative to this script (dev / git checkout).
resolve_home() {
  if [ -n "${AI_RUNTIME_HOME:-}" ]; then
    echo "$AI_RUNTIME_HOME"; return
  fi
  local src="${BASH_SOURCE[0]}"
  while [ -h "$src" ]; do src="$(readlink "$src")"; done
  cd "$(dirname "$src")/.." && pwd
}
HOME_DIR="$(resolve_home)"

block() {
  cat <<EOF
$BEGIN
# Managed by \`ai-runtime\`. Do not edit between these markers.
For **every task in any project**, use the shared AI Runtime at \`$LINK\`:
1. Read \`$LINK/AGENTS.md\` (the profile selector) and follow it.
2. Unity project (has \`Assets/\` + \`ProjectSettings/\`) -> \`AI/Unity/\`, else \`AI/Common/\`.
3. Load that profile's \`context/\`, then route to a skill per its \`Workflows.md\`.
4. Prepend your first response of the session with \`[AI_RUNTIME_LOADED · global · <Profile>]\` (\`<Profile>\` = Unity or Common) — confirms the global runtime was read. Verification only.
$END
EOF
}

strip_block() { # remove an existing managed block from stdin
  awk -v b="$BEGIN" -v e="$END" '
    $0==b {skip=1} !skip {print} $0==e {skip=0}'
}

# Add/remove the runtime paths in permissions.additionalDirectories so reading the
# global runtime from any project never prompts. Paths are resolved for THIS machine.
perms_wire() { # $1 = add | remove
  local op="$1" tmp; tmp="$(mktemp)"
  local input='{}'; [ -f "$SETTINGS" ] && input="$(cat "$SETTINGS")"
  if command -v jq >/dev/null 2>&1; then
    local expr
    if [ "$op" = add ]; then
      expr='.permissions.additionalDirectories = (((.permissions.additionalDirectories // []) + [$a,$b]) | unique)'
    else
      expr='.permissions.additionalDirectories = ((.permissions.additionalDirectories // []) - [$a,$b])'
    fi
    printf '%s' "$input" | jq --arg a "$LINK" --arg b "$HOME_DIR" "$expr" > "$tmp" 2>/dev/null \
      || { rm -f "$tmp"; echo "  ! could not update $SETTINGS (invalid JSON?) — add read scope manually" >&2; return 1; }
  elif command -v python3 >/dev/null 2>&1; then
    OP="$op" A="$LINK" B="$HOME_DIR" python3 - "$SETTINGS" > "$tmp" 2>/dev/null <<'PY' \
      || { rm -f "$tmp"; echo "  ! could not update $SETTINGS — add read scope manually" >&2; return 1; }
import json, os, sys
try:
    d = json.load(open(sys.argv[1]))
    if not isinstance(d, dict): d = {}
except Exception:
    d = {}
perm = d.setdefault("permissions", {})
ad = perm.get("additionalDirectories") or []
a, b, op = os.environ["A"], os.environ["B"], os.environ["OP"]
if op == "add":
    for x in (a, b):
        if x not in ad: ad.append(x)
else:
    ad = [x for x in ad if x not in (a, b)]
perm["additionalDirectories"] = ad
json.dump(d, sys.stdout, indent=2)
PY
  else
    rm -f "$tmp"
    echo "  ! no jq/python3 — add to $SETTINGS manually:" >&2
    echo "      permissions.additionalDirectories += [\"$LINK\", \"$HOME_DIR\"]" >&2
    return 2
  fi
  mv "$tmp" "$SETTINGS"
}

cmd_install() {
  [ -f "$HOME_DIR/AGENTS.md" ] || { echo "runtime not found at $HOME_DIR" >&2; exit 1; }
  mkdir -p "$CLAUDE_DIR"
  ln -sfn "$HOME_DIR" "$LINK"
  local body=""
  [ -f "$GLOBAL_MD" ] && body="$(strip_block < "$GLOBAL_MD")"
  { printf '%s' "$body"; [ -n "$body" ] && printf '\n\n'; block; } > "$GLOBAL_MD"
  echo "installed: $LINK -> $HOME_DIR"
  echo "updated:   $GLOBAL_MD (managed block)"
  perms_wire add && echo "updated:   $SETTINGS (read scope: no prompts to read the runtime)" || true
}

cmd_uninstall() {
  [ -L "$LINK" ] && rm "$LINK" && echo "removed link $LINK"
  if [ -f "$GLOBAL_MD" ]; then
    strip_block < "$GLOBAL_MD" | sed -e :a -e '/^\n*$/{$d;N;ba}' > "$GLOBAL_MD.tmp"
    mv "$GLOBAL_MD.tmp" "$GLOBAL_MD"
    echo "removed managed block from $GLOBAL_MD"
  fi
  [ -f "$SETTINGS" ] && perms_wire remove && echo "removed read scope from $SETTINGS" || true
}

cmd_status() {
  echo "runtime home : $HOME_DIR"
  echo "link         : $LINK -> $([ -L "$LINK" ] && readlink "$LINK" || echo '(none)')"
  echo "global md    : $([ -f "$GLOBAL_MD" ] && grep -q "$BEGIN" "$GLOBAL_MD" && echo 'wired' || echo 'not wired')"
  echo "read scope   : $([ -f "$SETTINGS" ] && grep -q "$HOME_DIR" "$SETTINGS" && echo 'wired' || echo 'not wired')"
}

cmd_update() {
  if [ -d "$HOME_DIR/.git" ]; then
    git -C "$HOME_DIR" pull --ff-only && echo "updated (git pull)"
  else
    echo "installed via Homebrew — run: brew upgrade ai-runtime"
  fi
}

case "${1:-}" in
  install)   cmd_install ;;
  uninstall) cmd_uninstall ;;
  status)    cmd_status ;;
  update)    cmd_update ;;
  *) echo "usage: ai-runtime {install|uninstall|status|update}" >&2; exit 2 ;;
esac
